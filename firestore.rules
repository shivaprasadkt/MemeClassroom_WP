rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user has admin role
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper: check if user is expert or admin
    function isExpertOrAdmin() {
      return request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'expert' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // ─── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId || isAdmin();
    }

    // ─── Memes ──────────────────────────────────────────────────────────────
    // Public memes are readable by all authenticated users.
    // Private/draft memes are only readable by their creator or admin.
    match /memes/{memeId} {
      allow read: if request.auth != null && (
        resource.data.visibility == "public" ||
        resource.data.creator_id == request.auth.uid ||
        isAdmin()
      );
      allow create: if request.auth != null && request.resource.data.creator_id == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.creator_id == request.auth.uid || isAdmin()
      );
      allow delete: if request.auth != null && (
        resource.data.creator_id == request.auth.uid || isAdmin()
      );
    }

    // ─── Templates ──────────────────────────────────────────────────────────
    // Only approved templates are publicly visible.
    // Any authenticated user can contribute (create) a template for approval.
    // Only admins can approve, update status, or delete templates.
    match /templates/{templateId} {
      allow read: if request.auth != null && (
        resource.data.status == "approved" || isAdmin()
      );
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // ─── Taxonomy Counters ───────────────────────────────────────────────────
    // Authenticated users can write counts; only admin reads all counts.
    match /custom_counts/{docId} {
      allow read: if isAdmin();
      allow write: if request.auth != null;
    }

    // ─── Shared Config (taxonomy, etc.) ─────────────────────────────────────
    match /configs/{configId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ─── User Stats ──────────────────────────────────────────────────────────
    match /user_stats/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // ─── Comments ───────────────────────────────────────────────────────────
    match /comments/{commentId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && (
        !request.resource.data.keys().hasAll(['is_expert_comment']) ||
        request.resource.data.is_expert_comment != true ||
        isExpertOrAdmin()
      );
      allow delete: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ─── Staffroom Posts ─────────────────────────────────────────────────────
    match /staffroom_posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (resource.data.author_id == request.auth.uid || isAdmin());
      allow delete: if request.auth != null && resource.data.author_id == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ─── Staffroom Replies ───────────────────────────────────────────────────
    match /staffroom_replies/{replyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (resource.data.author_id == request.auth.uid || isAdmin());
      allow delete: if request.auth != null && resource.data.author_id == request.auth.uid;
      allow delete: if isAdmin() || isExpertOrAdmin();
    }

  }
}
